# Required: Anthropic API key for Claude AI scoring
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: set a password to gate the beta.
# Leave blank (or omit) to allow open access.
BETA_ACCESS_CODE=your-secret-code-here

# Optional: override where photos are stored on disk.
# Defaults to ./storage in local dev.
# On Render, this should point to your mounted persistent disk (e.g. /data/photocull).
# STORAGE_DIR=/data/photocull
